{
  "html": "<!-- Type 03: 모바일 기본 아이콘 팩 그리드 -->\n<div class=\"template-a-card icons-card\">\n  <div class=\"card-inner-padding\">\n    <div class=\"icon-grid\">\n      <div class=\"icon-tile\" data-icon=\"icon_home\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_home.svg\" alt=\"Home\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Home</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_allmenu\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_allmenu.svg\" alt=\"All Menu\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">All Menu</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_close\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_close.svg\" alt=\"Close\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Close</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_back\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_back.svg\" alt=\"Back\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Back</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_search\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_search.svg\" alt=\"Search\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Search</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_check\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_check.svg\" alt=\"Check\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Check</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_up\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_up.svg\" alt=\"Up\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Up</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_down\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_down.svg\" alt=\"Down\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Down</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_refresh\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_refresh.svg\" alt=\"Refresh\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Refresh</span>\n      </div>\n      <div class=\"icon-tile\" data-icon=\"icon_right\">\n        <div class=\"tile-icon-wrapper\">\n          <img src=\"../assets/images/icon/icon_right.svg\" alt=\"Right\" class=\"tile-icon\">\n        </div>\n        <span class=\"tile-name\">Right</span>\n      </div>\n    </div>\n  </div>\n</div>",
  "css": "/* CSS Type 03: Icon Showcase Grid styling */\n.template-a-card.icons-card {\n  padding: 24px 20px;\n  background: #ffffff;\n}\n\n.icon-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 12px;\n  width: 100%;\n}\n\n.icon-tile {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 8px;\n  padding: 12px 6px;\n  background: #f8fafc;\n  border: 1px solid #f1f5f9;\n  border-radius: 12px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.icon-tile:hover {\n  background: #EEEFFA;\n  border-color: #585DCB;\n  transform: translateY(-2px);\n}\n\n.tile-icon-wrapper {\n  width: 36px;\n  height: 36px;\n  background: #ffffff;\n  border-radius: 8px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 5px rgba(0,0,0,0.02);\n}\n\n.tile-icon {\n  width: 24px;\n  height: 24px;\n}\n\n.tile-name {\n  font-size: 10px;\n  color: #64748b;\n  font-weight: 500;\n  text-align: center;\n  font-family: 'Outfit', sans-serif;\n}"
}
